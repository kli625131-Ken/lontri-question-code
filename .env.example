# Copy this file to .env and replace all placeholder secrets before running.

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=problem_db
MYSQL_USER=lontri
MYSQL_PASSWORD=change_me_app_password
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=80
TZ=Asia/Shanghai

JWT_SECRET=change_me_jwt_secret_at_least_32_characters
APP_DEFAULT_PASSWORD=change_me_default_password

OPS_IMPORT_BOOTSTRAP_ENABLED=true
OPS_IMPORT_BOOTSTRAP_FILE=LONTRI项目运维记录.xlsx
OPS_IMPORT_RESET_ON_BOOTSTRAP=false
OPS_IMPORT_DEFAULT_REMIND_AFTER_DAYS=7

# Optional: point backend to another database instead of the compose mysql service.
# SPRING_DATASOURCE_URL=jdbc:mysql://your-host:3306/problem_db?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
